        '<div class="cd cd-g" style="text-align:center;padding:20px;cursor:pointer" onclick="F.promptLab()">' +
        '<div style="font-size:32px;margin-bottom:6px">🧪</div><strong>مختبر البرومبت</strong>' +
        '<p style="font-size:10px;color:var(--text3);margin-top:3px">اختبر أي prompt مباشرة</p></div>' +

        '<div class="cd cd-g" style="text-align:center;padding:20px;cursor:pointer" onclick="F.modelCompare()">' +
        '<div style="font-size:32px;margin-bottom:6px">⚖️</div><strong>مقارنة نماذج</strong>' +
        '<p style="font-size:10px;color:var(--text3);margin-top:3px">قارن بين نموذجين</p></div>' +

        '<div class="cd cd-g" style="text-align:center;padding:20px;cursor:pointer" onclick="F.showLog()">' +
        '<div style="font-size:32px;margin-bottom:6px">📋</div><strong>سجل النظام</strong>' +
        '<p style="font-size:10px;color:var(--text3);margin-top:3px">جميع أحداث المصنع</p></div>' +

        '<div class="cd cd-g" style="text-align:center;padding:20px;cursor:pointer" onclick="F.deployAllAgents()">' +
        '<div style="font-size:32px;margin-bottom:6px">🌐</div><strong>نشر كل الوكلاء</strong>' +
