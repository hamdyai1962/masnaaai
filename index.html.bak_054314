        '<div class="cd cd-g" style="text-align:center;padding:20px;cursor:pointer" onclick="F.clearAll()">' +
        '<div style="font-size:32px;margin-bottom:6px">🗑️</div><strong style="color:var(--red)">مسح كل البيانات</strong>' +
        '<p style="font-size:10px;color:var(--text3);margin-top:3px">حذف نهائي لكل شيء</p></div>' +
