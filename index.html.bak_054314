        '<p style="font-size:10px;color:var(--text3);margin-top:3px">JSON كامل للنسخ الاحتياطي</p></div>' +

        '<div class="cd cd-g" style="text-align:center;padding:20px;cursor:pointer" onclick="F.importAgents()">' +
        '<div style="font-size:32px;margin-bottom:6px">📥</div><strong>استيراد وكلاء</strong>' +
        '<p style="font-size:10px;color:var(--text3);margin-top:3px">من ملف JSON</p></div>' +

        '<div class="cd cd-g" style="text-align:center;padding:20px;cursor:pointer" onclick="F.deployFactory()">' +
